APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Satukan tampilan: HP & tablet memakai view desktop (responsif). false = kembali ke view hp/tablet terpisah.
# NEONFLUX_UNIFIED_DESKTOP_VIEWS=true
# Produksi (contoh canonical www): APP_URL=https://www.neonflux.my.id
# Alihkan apex ke www — hanya jika APP_URL sudah memakai www:
FORCE_WWW=false

# iPaymu HTTP (hindari timeout ~30s / 0 bytes di VPS — IPv4 + timeout lebih panjang)
# IPAYMU_HTTP_TIMEOUT=90
# IPAYMU_HTTP_CONNECT_TIMEOUT=25
# IPAYMU_FORCE_IPV4=true
# Saat iPaymu 500/502/503/504 atau timeout koneksi: jumlah percobaan tambahan (default 2 = total 3x)
# IPAYMU_RETRY_ATTEMPTS=2
# IPAYMU_RETRY_SLEEP_MS=800

# TokoVoucher webhook GET (report IP): opsional batasi IP sumber (188.166.243.56). POST pakai header X-TokoVoucher-Authorization.
# URL webhook: https://www.neonflux.my.id/api/tokovoucher/webhook
# TOKOVOUCHER_WEBHOOK_VERIFY_IP=false
# TOKOVOUCHER_WEBHOOK_ALLOWED_IPS=188.166.243.56
# Setelah bayar: panggil ulang /api/tokovoucher/webhook (relay) untuk cek status TV + retry kirim. Minimal 16 karakter; kosong = nonaktif.
# TOKOVOUCHER_INTERNAL_RELAY_SECRET=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Payment Gateways (Fallbacks if DB settings are empty)
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

DUITKU_MODE=sandbox

# WhatsApp API (Orbit)
ORBIT_WA_BASE_URL=https://orbitwaapi.site/api/v1
ORBIT_WA_API_KEY=

# TokoVoucher — API JSON (pascabayar-inq, status, dll.): tetap https://api — jangan trx-ip (sering 503 untuk POST JSON).
TOKOVOUCHER_API_BASE=https://api.tokovoucher.net
# Transaksi: host api → GET /v1/transaksi (JSON). Host trx-ip → GET /trx (teks), lihat https://docs.tokovoucher.net/transaksi/get-text
TOKOVOUCHER_TRANSACTION_BASE=https://api.tokovoucher.net
# Opsional: jika BASE sering 502/503, isi host cadangan (jalur IP memakai /trx otomatis):
# TOKOVOUCHER_TRANSACTION_FALLBACK=http://trx-ip.tokovoucher.net
TOKOVOUCHER_TRANSACTION_FALLBACK=
# Paksa IPv4 outbound (kurangi "IP Not Allowed" bila panel hanya kenali IPv4)
TOKOVOUCHER_FORCE_IPV4=true
# Catatan dok TokoVoucher: error HTTP & network timeout = anggap pending sampai callback / cek status ~10 menit.
# Whitelist IP server Anda di member TokoVoucher; IP 188.166.243.56 sering untuk izinkan callback masuk di firewall VPS.

# Cek ID (top-up): coba POST /v1/pascabayar-inq TokoVoucher dulu (nama = customer_name). Game prabayar biasanya tidak masuk inquiry ini.
CHECK_ID_TOKOVOUCHER_PASCABAYAR=true
# Jika inquiry TV tidak ada nama, pakai Codashop untuk nickname game (initPayment). Matikan hanya jika Anda ingin sumber 100% TV.
CHECK_ID_CODASHOP_FALLBACK=true

# Security & Background Tasks
CRON_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://neunflux.my.id/auth/google/callback

