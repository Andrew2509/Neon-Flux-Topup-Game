								"jwt",
								"generate"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify Token",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/jwt/verify",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"jwt",
								"verify"
							]
						}
					},
					"response": []
				}
			]
		}
