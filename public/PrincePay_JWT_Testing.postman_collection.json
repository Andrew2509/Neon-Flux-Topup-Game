{
	"info": {
		"_postman_id": "a9e587fb-c6f4-4e66-9d34-459bf410a3b6",
		"name": "PrincePay JWT & Auth",
		"description": "Collection for testing JWT and Auth implementation in PrincePay Gaming (Laravel).\n\n### Gambaran Sistem Website Top Up Besar:\n1. User pilih game\n2. Pilih nominal\n3. Buat pesanan\n4. Bayar\n5. Payment gateway konfirmasi\n6. Order dikirim ke supplier\n7. Item masuk ke akun game\n8. Status transaksi sukses",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "1. Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": [
